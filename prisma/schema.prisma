generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 選手マスタ
// ============================================================

model Player {
  id           String   @id @default(cuid())
  name         String
  nameKana     String   @default("")
  jerseyNumber Int
  imageUrl     String? // Vercel Blob のURL、または data URL (Blob未設定時)
  isBeginner   Boolean  @default(false)
  canPlayGk    Boolean  @default(false)
  isActive     Boolean  @default(true)
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 基本プロフィール
  grade              Int? // 学年 (1〜6)
  dominantFoot       String  @default("") // RIGHT / LEFT / BOTH / ""(未設定)
  isCaptainCandidate Boolean @default(false)

  // 能力値 (0=未設定, 1〜5)
  stamina   Int @default(0) // 体力
  technique Int @default(0) // 技術
  speed     Int @default(0) // スピード
  defense   Int @default(0) // 守備力
  attack    Int @default(0) // 攻撃力

  positions         PlayerPosition[]
  matchDayPlayers   MatchDayPlayer[]
  lineupAssignments LineupAssignment[]
  awards            PlayerAward[]
  mvpVotes          MvpVote[]

  @@unique([jerseyNumber])
  @@index([isActive])
  @@index([grade])
}

// ============================================================
// ポジションマスタ (3-3-1 の 8ポジション)
// ============================================================

model Position {
  id        Int    @id @default(autoincrement())
  code      String @unique // GK, LDF, CDF, RDF, LMF, CMF, RMF, FW
  name      String // 表示名 (日本語)
  category  String // GK / DF / MF / FW
  sortOrder Int

  playerPositions   PlayerPosition[]
  lineupAssignments LineupAssignment[]
}

// 選手ごとのポジション適性
// aptitudeLevel: 3=得意, 2=普通, 1=経験あり, 0=対応不可
model PlayerPosition {
  id            String  @id @default(cuid())
  playerId      String
  positionId    Int
  aptitudeLevel Int     @default(0)
  isAvailable   Boolean @default(false)

  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([playerId, positionId])
  @@index([positionId])
}

// ============================================================
// 試合日
// ============================================================

model MatchDay {
  id              String   @id @default(cuid())
  matchDate       DateTime @db.Date
  eventName       String   @default("")
  venue           String   @default("")
  meetingTime     String   @default("") // "08:30" のような文字列
  numberOfMatches Int      @default(1)
  formation       String   @default("3-3-1") // FORMATIONS のキー (3-3-1 / 2-3-2 / 2-4-1-W / 2-4-1-V / 3-2-2)
  notes           String   @default("")
  status          String   @default("NOT_GENERATED") // NOT_GENERATED / GENERATED / EDITING / CONFIRMED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  players           MatchDayPlayer[]
  matches           Match[]
  generationSetting GenerationSetting?
  histories         GenerationHistory[]
  awards            PlayerAward[]
  mvpVotes          MvpVote[]
  boardPosts        BoardPost[]

  @@index([matchDate])
}

// 試合日ごとの参加選手 (当日限定の上書き情報を持つ)
model MatchDayPlayer {
  id               String  @id @default(cuid())
  matchDayId       String
  playerId         String
  attendanceStatus String  @default("PRESENT") // PRESENT / ABSENT / LATE / LEAVE_EARLY / INJURED / SICK
  isBeginnerOnDay  Boolean @default(false)
  canPlayGk        Boolean @default(false)
  canPlay          Boolean @default(true) // 出場不可フラグ (falseで出場不可)
  maxPlayingSlots  Int? // 出場枠数の上限 (null=無制限)
  priority         Int     @default(0) // 出場優先度 (大きいほど優先)
  condition        String  @default("") // 当日の体調メモ
  notes            String  @default("")

  matchDay MatchDay @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchDayId, playerId])
  @@index([playerId])
}

// ============================================================
// 試合
// ============================================================

model Match {
  id           String  @id @default(cuid())
  matchDayId   String
  matchNumber  Int
  opponentName String  @default("")
  startTime    String  @default("") // "10:00" のような文字列
  courtName    String  @default("")
  status       String  @default("SCHEDULED")
  scoreFor     Int?
  scoreAgainst Int?
  notes        String  @default("")

  matchDay MatchDay      @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  periods  MatchPeriod[]

  @@unique([matchDayId, matchNumber])
}

// 試合の時間帯区分 (1試合 = 4区分、各7分30秒 = 450秒)
model MatchPeriod {
  id           String @id @default(cuid())
  matchId      String
  periodType   String // FIRST_HALF_FIRST / FIRST_HALF_SECOND / SECOND_HALF_FIRST / SECOND_HALF_SECOND
  periodOrder  Int // 1〜4
  startSecond  Int // 試合内の開始秒
  durationSecs Int    @default(450)

  match       Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  assignments LineupAssignment[]

  @@unique([matchId, periodOrder])
}

// 区分ごとのポジション割り当て
model LineupAssignment {
  id             String   @id @default(cuid())
  matchPeriodId  String
  playerId       String
  positionId     Int
  isLocked       Boolean  @default(false) // 手動固定 (再生成しても変更しない)
  isManual       Boolean  @default(false) // 手動で配置された
  generatedScore Float? // 自動編成時の評価点
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  matchPeriod MatchPeriod @relation(fields: [matchPeriodId], references: [id], onDelete: Cascade)
  player      Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  position    Position    @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([matchPeriodId, positionId]) // 同じ区分に同じポジションは1人
  @@unique([matchPeriodId, playerId]) // 同じ区分に同じ選手は1回
  @@index([playerId])
}

// ============================================================
// 自動編成設定・履歴
// ============================================================

model GenerationSetting {
  id                    String @id @default(cuid())
  matchDayId            String @unique
  beginnerLimit         Int    @default(2) // 同一区分の初心者上限
  fairnessWeight        Int    @default(50) // 出場均等の重み
  aptitudeWeight        Int    @default(30) // 適性の重み
  continuityPenalty     Int    @default(20) // 連続出場ペナルティ
  positionRepeatPenalty Int    @default(10) // 同ポジション連続ペナルティ
  randomnessWeight      Int    @default(15) // ランダム性の強さ
  presetType            String @default("FAIRNESS") // FAIRNESS / WIN / DEVELOPMENT / RANDOM

  matchDay MatchDay @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
}

// ============================================================
// 表彰・投票・掲示板
// ============================================================

// 大会 (試合日) ごとの表彰 (優秀選手賞など)
model PlayerAward {
  id         String   @id @default(cuid())
  matchDayId String
  playerId   String
  awardName  String   @default("優秀選手賞")
  notes      String   @default("")
  createdAt  DateTime @default(now())

  matchDay MatchDay @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([matchDayId])
  @@index([playerId])
}

// 優秀選手の匿名投票 (投票者の情報は保存しない)
model MvpVote {
  id         String   @id @default(cuid())
  matchDayId String
  playerId   String
  createdAt  DateTime @default(now())

  matchDay MatchDay @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([matchDayId])
}

// 掲示板 (学年別 / 試合日別)
model BoardPost {
  id         String   @id @default(cuid())
  boardType  String // GRADE / MATCHDAY
  grade      Int? // boardType=GRADE のとき 0(全体)〜6(学年)
  matchDayId String? // boardType=MATCHDAY のとき対象の試合日
  authorName String   @default("匿名")
  body       String
  createdAt  DateTime @default(now())

  matchDay MatchDay? @relation(fields: [matchDayId], references: [id], onDelete: Cascade)

  @@index([boardType, grade, createdAt])
  @@index([matchDayId, createdAt])
}

model GenerationHistory {
  id             String   @id @default(cuid())
  matchDayId     String
  generationSeed Int
  generationType String // FULL_DAY / MATCH / PERIOD
  resultSummary  String   @default("")
  createdAt      DateTime @default(now())

  matchDay MatchDay @relation(fields: [matchDayId], references: [id], onDelete: Cascade)

  @@index([matchDayId])
}
