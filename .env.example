# PostgreSQL 接続文字列 (Neon の場合はダッシュボードからコピー)
# 例: postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://dev:dev@localhost:5432/junior_soccer"

# Vercel Blob (選手画像の保存に使用。未設定の場合は画像をDBに保存します)
# Vercel ダッシュボード > Storage > Blob で作成しトークンを取得
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ログイン認証 (スタッフ共有パスワード)
# 設定すると全ページでログインが必要になります。未設定なら認証なしで動作します。
# APP_PASSWORD="your-team-password"

# Cookie署名用の秘密鍵 (任意。未設定時は APP_PASSWORD から導出)
# openssl rand -hex 32 などで生成したランダムな文字列を推奨
# AUTH_SECRET="random-secret-string"
